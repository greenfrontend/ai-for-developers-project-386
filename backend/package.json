{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run generate:api && npm run build && npm run test",
    "db:migrate": "tsx src/db/migrate.ts",
    "dev": "tsx watch src/server.ts",
    "generate:api": "openapi-ts",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "11.1.0",
    "@fastify/response-validation": "3.0.3",
    "@platformatic/fastify-openapi-glue": "5.1.0",
    "ajv-formats": "3.0.1",
    "dotenv": "17.2.3",
    "drizzle-orm": "0.45.1",
    "fastify": "5.6.2",
    "postgres": "3.4.7"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.98.2",
    "@types/node": "24.10.2",
    "drizzle-kit": "0.31.8",
    "tsx": "4.20.6",
    "typescript": "6.0.3",
    "vitest": "4.0.15"
  }
}
